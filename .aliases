alias zconfig="nvim ~/.zshrc"
alias zrel="source ~/.zshrc"

alias artisan="php artisan"
alias sail='sh $([ -f sail ] && echo sail || echo vendor/bin/sail)'

releasethekraken() {
  if ping -c 1 -W 1 10.0.0.30 &>/dev/null; then
    ssh wolfius@10.0.0.30 "$@"
  else
    ssh wolfius@kraken "$@"
  fi
}

unleashragnarok() {
  if ping -c 1 -W 1 10.0.0.2 &>/dev/null; then
    ssh wolfius@10.0.0.2 "$@"
  else
    ssh wolfius@ragnarok "$@"
  fi
}

alias vi="nvim"

alias ls="eza --icons --group-directories-first"
alias ll="eza --icons --group-directories-first -la"

alias storm="open -a 'phpstorm.app' ."

alias convertvideo='convert_video'
alias convertvideohdr='convert_video_hdr_aggressive'

alias ga='git add'
alias gs='git status'
alias gcm='git commit -m'
alias gcb='git checkout -b'
alias gco='git checkout'
alias gf='git fetch'
alias gpl='git pull'
alias gp='git push'

# Make sudo vi/vim use neovim (uses full path for sudo's restricted PATH)
sudo() {
    if [[ "$1" == "vi" || "$1" == "vim" ]]; then
        shift
        command sudo "$(command -v nvim)" "$@"
    else
        command sudo "$@"
    fi
}

# Make sudoedit use neovim (preserves SUDO_EDITOR from env)
alias sudoedit='sudo SUDO_EDITOR="$(command -v nvim)" -e'
